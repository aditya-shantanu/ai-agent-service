# Copy to .env (gitignored — NEVER commit the real file) and fill in the
# provider key(s) your agents should use. Every line here lands verbatim in
# the hermes-provider-keys Secret and is injected into every sandbox via
# envFrom, so any env var Hermes understands works.
#
# Apply with:  make set-provider-key
#
# Get a Gemini key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Alternatives / additions (uncomment what you use):
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
